# Verified production stream URL (do not hardcode in source)
NEXT_PUBLIC_RADIO_STREAM_URL=https://your-verified-stream-url.example/stream

# Public site URL for canonical, OG, and JSON-LD
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Upstash Redis (optional — in-memory fallback in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
